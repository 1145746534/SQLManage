<UserControl x:Class="SQLManage.Views.ReportManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:local="clr-namespace:SQLManage.Views"
             xmlns:util="clr-namespace:SQLManage.Util"          
             xmlns:p="http://prismlibrary.com/" 
             mc:Ignorable="d" 
             mah:DialogParticipation.Register="{Binding}"
             d:DesignHeight="840" d:DesignWidth="1280">

    <UserControl.Resources>
        <ResourceDictionary>
            <!-- 转换器 -->
            <util:ResultConverter x:Key="ResultConverter" />
            <util:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <!-- 日期选择器样式 -->
            <Style x:Key="DatePickerStyle" TargetType="{x:Type DatePicker}">
                <Setter Property="Foreground" Value="#FF333333"/>
                <Setter Property="IsTodayHighlighted" Value="True"/>
                <Setter Property="SelectedDateFormat" Value="Short"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="2"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint=".5,0" StartPoint=".5,1">
                            <GradientStop Color="#FFA3AEB9" Offset="0"/>
                            <GradientStop Color="#FF8399A9" Offset="0.375"/>
                            <GradientStop Color="#FF718597" Offset="0.375"/>
                            <GradientStop Color="#FF617584" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type DatePicker}">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Padding="{TemplateBinding Padding}" 
                                    CornerRadius="5">
                                <Grid x:Name="PART_Root">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <DatePickerTextBox x:Name="PART_TextBox" 
                                                      Focusable="{TemplateBinding Focusable}"
                                                      HorizontalContentAlignment="Center"
                                                      VerticalContentAlignment="Stretch"/>

                                    <Button x:Name="PART_Button" 
                                            Grid.Column="1"
                                            Foreground="{TemplateBinding Foreground}"
                                            Focusable="False"
                                            HorizontalAlignment="Left" 
                                            Margin="3,0,3,0"
                                            Template="{StaticResource DropDownButtonTemplate}"/>

                                    <Popup x:Name="PART_Popup" 
                                           Grid.ColumnSpan="2"
                                           AllowsTransparency="True" 
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=PART_TextBox}" 
                                           StaysOpen="False"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 筛选区域 -->
        <Border Grid.Row="0" Background="#F5F7FA" Padding="12,10" 
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 基础筛选 -->
                <StackPanel Orientation="Horizontal" Grid.Row="0">
                    <!-- 时间范围 -->
                    <TextBlock Text="时间范围" VerticalAlignment="Center" 
                             Margin="0,0,6,0" FontSize="13" Foreground="#555"/>
                    <mah:DateTimePicker x:Name="StartDateTimePicker"
                        SelectedDateTime="{Binding StartDateTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Width="180" Height="30" 
                        mah:TextBoxHelper.ClearTextButton="True"
                        Culture="zh-CN" 
                        SelectedDateFormat="Short"
                        SelectedTimeFormat="Long"
                        FontSize="13"/>
                    <TextBlock Text="至" VerticalAlignment="Center" 
                             Margin="8,0,8,0" FontSize="13" Foreground="#555"/>
                    <mah:DateTimePicker x:Name="EndDateTimePicker"
                        SelectedDateTime="{Binding EndDateTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Width="180" Height="30" 
                        mah:TextBoxHelper.ClearTextButton="True"
                        Culture="zh-CN" 
                        SelectedDateFormat="Short"
                        SelectedTimeFormat="Long"
                        FontSize="13"/>

                    <!-- 轮毂型号 -->
                    <TextBlock Text="轮毂型号" VerticalAlignment="Center" 
                             Margin="15,0,6,0" FontSize="13" Foreground="#555"/>
                    <TextBox Text="{Binding FilterModel, UpdateSourceTrigger=PropertyChanged}"
                        Width="120" Height="30" 
                        mah:TextBoxHelper.ClearTextButton="True"
                        mah:TextBoxHelper.Watermark="模糊搜索" 
                        FontSize="13" 
                        Padding="5,2"/>

                    <!-- 样式 -->
                    <TextBlock Text="样式" VerticalAlignment="Center" 
                             Margin="15,0,6,0" FontSize="13" Foreground="#555"/>
                    <ComboBox SelectedItem="{Binding FilterWheelStyle, Mode=TwoWay}"
                        ItemsSource="{Binding WheelStyles}" 
                        Width="100" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.ComboBox}"/>

                    <!-- 工站 -->
                    <TextBlock Text="工站" VerticalAlignment="Center" 
                             Margin="15,0,6,0" FontSize="13" Foreground="#555"/>
                    <ComboBox SelectedItem="{Binding FilterStation, Mode=TwoWay}"
                        ItemsSource="{Binding StationOptions}" 
                        Width="100" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.ComboBox}"/>

                    <!-- 检查结果 -->
                    <TextBlock Text="结果" VerticalAlignment="Center" 
                             Margin="15,0,6,0" FontSize="13" Foreground="#555"/>
                    <ComboBox SelectedItem="{Binding FilterResult, Mode=TwoWay}"
                        ItemsSource="{Binding ResultOptions}" 
                        Width="100" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.ComboBox}"/>

                    <!-- 查询/重置按钮 -->
                    <Button Content="查 询" Command="{Binding QueryCommand}"
                        Margin="15,0,5,0" Width="75" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"/>
                    <Button Content="重 置" Command="{Binding ResetFilterCommand}"
                        Width="75" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.Button.Square}"/>
                </StackPanel>

                <!-- 展开/收起按钮 -->
                <StackPanel Orientation="Horizontal" Grid.Row="0" 
                         HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button Content="▼ 收起高级筛选"
                            Command="{Binding ExpandFilterCommand}"
                            Style="{StaticResource MahApps.Styles.Button.Circle}" 
                            FontSize="12" Width="110" Height="28"
                            Visibility="{Binding IsFilterExpanded, 
                                     Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Content="▲ 显示高级筛选"
                            Command="{Binding ExpandFilterCommand}"
                            Style="{StaticResource MahApps.Styles.Button.Circle}" 
                            FontSize="12" Width="110" Height="28"
                            Visibility="{Binding IsFilterExpanded, 
                                     Converter={StaticResource BoolToVisibilityConverter}, 
                                     ConverterParameter=Inverted}"/>
                </StackPanel>

                <!-- 高级筛选 -->
                <StackPanel Orientation="Horizontal" Grid.Row="1"
                         Visibility="{Binding IsFilterExpanded, 
                                 Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="0,10,0,0">
                    <TextBlock Text="上报方式" VerticalAlignment="Center" 
                             Margin="0,0,6,0" FontSize="13" Foreground="#555"/>
                    <ComboBox SelectedItem="{Binding FilterReportWay, Mode=TwoWay}"
                        ItemsSource="{Binding ReportWayOptions}" 
                        Width="100" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.ComboBox}"/>

                    <!-- NG编号 -->
                    <TextBlock Text="NG编号" VerticalAlignment="Center" 
                             Margin="15,0,6,0" FontSize="13" Foreground="#555"/>
                    <TextBox Text="{Binding FilterRemark, UpdateSourceTrigger=PropertyChanged}"
                        Width="120" Height="30" 
                        mah:TextBoxHelper.ClearTextButton="True"
                        mah:TextBoxHelper.Watermark="缺陷编码" 
                        FontSize="13" 
                        Padding="5,2"/>

                    <!-- 轮毂轮型 -->
                    <TextBlock Text="轮型" VerticalAlignment="Center" 
                             Margin="15,0,6,0" FontSize="13" Foreground="#555"/>
                    <TextBox Text="{Binding FilterWheelType, UpdateSourceTrigger=PropertyChanged}"
                        Width="120" Height="30" 
                        mah:TextBoxHelper.ClearTextButton="True"
                        mah:TextBoxHelper.Watermark="轮型名称" 
                        FontSize="13" 
                        Padding="5,2"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 工具栏 -->
        <Border Grid.Row="1" Background="White" Padding="10,6" 
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="📊 数据统计" Command="{Binding DataStatisticsCommand}"
                        Margin="0,0,8,0" Width="105" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.Button.Square}"/>
                    <Button Content="📥 导出指定时间数据" Command="{Binding DataExportCommand}"
                        Margin="0,0,8,0" Width="155" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.Button.Square}"/>
                    <Button Content="⚡ 刷新最新100条" Command="{Binding DataRefreshCommand}"
                        Width="120" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.Button.Square}"/>
                    <Button Content="📋 上一个班次导出" Command="{Binding DataExportExcelCommand}"
                        Margin="8,0,8,0" Width="155" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.Button.Square}"/>
                    <Button Content="📄 导出当前查询数据" Command="{Binding ExportCurrentDataCommand}"
                        Width="155" Height="30" 
                        FontSize="13"
                        Style="{StaticResource MahApps.Styles.Button.Square}"/>
                </StackPanel>

                <!-- 记录数统计 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                         VerticalAlignment="Center">
                    <TextBlock Text="共" FontSize="13" Foreground="#666" 
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding QueryCount}" 
                             Foreground="#2196F3" 
                             FontSize="14" 
                             FontWeight="SemiBold" 
                             Width="40" 
                             Margin="5,0" 
                             VerticalAlignment="Center"/>
                    <TextBlock Text="条记录" FontSize="13" Foreground="#666" 
                             VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 数据区域 -->
        <Border Grid.Row="2" Padding="8" Background="White" Margin="0,5">
            <Grid>
                <!-- 识别数据表格 -->
                <DataGrid ItemsSource="{Binding IdentificationDatas}"
                    Visibility="{Binding IdentificationDataVisibility}"
                    Background="Transparent" 
                    BorderThickness="1" 
                    BorderBrush="#E0E0E0"
                    IsReadOnly="True" 
                    FontSize="13" 
                    Foreground="#333"
                    AutoGenerateColumns="False" 
                    CanUserResizeColumns="True"
                    SelectionMode="Extended" 
                    GridLinesVisibility="All"
                    HeadersVisibility="Column"
                    RowBackground="White" 
                    AlternatingRowBackground="#FAFAFA"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="GridLinesVisibility" Value="All"/>
                            <Setter Property="HeadersVisibility" Value="Column"/>
                            <Setter Property="AutoGenerateColumns" Value="False"/>
                            <Setter Property="CanUserResizeColumns" Value="True"/>
                            <Setter Property="SelectionMode" Value="Extended"/>
                            <Setter Property="IsReadOnly" Value="True"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#333"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="RowBackground" Value="White"/>
                            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
                            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
                            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="序号" Binding="{Binding ID}" 
                                         Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="轮毂型号" Binding="{Binding Model}" 
                                         Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="轮毂样式" Binding="{Binding WheelStyle}" 
                                         Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="轮毂高度" Binding="{Binding WheelHeight}" 
                                         Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="轮毂温度" Binding="{Binding WheelTemperature}" 
                                         Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="工站" Binding="{Binding Station}" 
                                         Width="80" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="检查结果" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ResultBool, 
                                             Converter={StaticResource ResultConverter}}"
                                             HorizontalAlignment="Center"
                                             FontWeight="Medium"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="NG编号" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Remark, 
                                             Converter={StaticResource ResultConverter}}"
                                             HorizontalAlignment="Center"
                                             FontWeight="Medium"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="上报方式" Binding="{Binding ReportWay}" 
                                         Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="相似度" Binding="{Binding Similarity}" 
                                         Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="识别时间" 
                                         Binding="{Binding RecognitionTime, 
                                                 StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}"
                                         Width="150" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 统计数据表格 -->
                <DataGrid ItemsSource="{Binding StatisticsDatas}"
                    Visibility="{Binding StatisticsDataVisibility}"
                    Background="Transparent" 
                    BorderThickness="1" 
                    BorderBrush="#E0E0E0"
                    IsReadOnly="True" 
                    FontSize="13" 
                    Foreground="#333"
                    AutoGenerateColumns="False" 
                    CanUserResizeColumns="True"
                    SelectionMode="Single" 
                    GridLinesVisibility="All"
                    HeadersVisibility="Column"
                    RowBackground="White" 
                    AlternatingRowBackground="#FAFAFA"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="GridLinesVisibility" Value="All"/>
                            <Setter Property="HeadersVisibility" Value="Column"/>
                            <Setter Property="AutoGenerateColumns" Value="False"/>
                            <Setter Property="CanUserResizeColumns" Value="True"/>
                            <Setter Property="SelectionMode" Value="Single"/>
                            <Setter Property="IsReadOnly" Value="True"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#333"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="RowBackground" Value="White"/>
                            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
                            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
                            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="序号" Binding="{Binding Index}" 
                                         Width="70" IsReadOnly="True"/>
                        <DataGridTextColumn Header="轮毂型号" Binding="{Binding Model}" 
                                         Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="样式" Binding="{Binding WheelStyle}" 
                                         Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="轮毂数量" Binding="{Binding WheelCount}" 
                                         Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="合格数" Binding="{Binding PassCount}" 
                                         Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="主要NG" Binding="{Binding MostOfNG}" 
                                         Width="*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 空状态提示 -->
                <TextBlock Text="请输入查询条件，点击「查询」按钮"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    FontSize="16" 
                    Foreground="#AAA"
                    Visibility="{Binding IdentificationDataVisibility, 
                             Converter={StaticResource BoolToVisibilityConverter}, 
                             ConverterParameter=Inverted}"
                    Opacity="0.6"/>
            </Grid>
        </Border>

        <!-- 数据纠正区域 -->
    </Grid>
</UserControl>
